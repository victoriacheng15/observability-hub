          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT\n  e.feature_id as metric,\n  AVG(e.value / NULLIF(v.value, 0)) as value\nFROM\n  analytics_metrics e\nJOIN\n  analytics_metrics v ON e.time = v.time AND e.feature_id = v.feature_id\nWHERE\n  e.kind = 'energy' AND v.kind = 'value_unit'\n  AND $__timeFilter(e.time)\nGROUP BY 1;",
          "refId": "A"
        }
      ],
      "title": "Efficiency (Joules per Unit)",
      "type": "gauge"
