      "pluginVersion": "12.3.1",
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH reading AS (\n  SELECT date_trunc('day', event_timestamp) as time, count(*) as c\n  FROM reading_analytics\n  WHERE event_type = 'extraction' AND $__timeFilter(event_timestamp)\n  GROUP BY 1\n), brain AS (\n  SELECT date_trunc('day', entry_date) as time, count(*) as c\n  FROM second_brain\n  WHERE $__timeFilter(created_at)\n  GROUP BY 1\n)\nSELECT \n  COALESCE(r.time, b.time) as \"time\",\n  COALESCE(r.c, 0) as \"Reading Extractions\",\n  COALESCE(b.c, 0) as \"Thought Entries\"\nFROM reading r\nFULL OUTER JOIN brain b ON r.time = b.time\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Cognitive Velocity: Extractions vs. Thoughts",
      "type": "timeseries"
    },
